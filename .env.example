# Copy to .env and adjust for your environment.
# docker-compose reads this file automatically for ${VAR} substitution.

# MongoDB Atlas Local connection.
MONGODB_URI=mongodb://mongo:27017/opssage-knowledge?directConnection=true

# Atlas Vector Search index configuration.
FACT_VECTOR_INDEX=fact-vector-index
FACT_VECTOR_DIMENSIONS=384
FACT_VECTOR_CANDIDATES_MULTIPLIER=20

# Startup embedding backfill: concurrency and overall timeout.
FACT_EMBED_CONCURRENCY=4
FACT_BACKFILL_TIMEOUT=5m

# HTTP port exposed by knowledge-mcp-server.
SERVER_PORT=8082

# Default number of items returned per page / per MCP tool call.
KNOWLEDGE_PAGE_SIZE=20

# Hard upper bound a caller can request per page.
KNOWLEDGE_MAX_PAGE_SIZE=100
